{
  "version": "1.0",
  "agent": {
    "name": "LeadQualBot",
    "description": "AI Lead Qualification Agent for Web Design Agencies",
    "model": "anthropic/claude-3.5-haiku",
    "max_tokens": 1000,
    "temperature": 0.7,
    "max_iterations": 10
  },
  "tools": [
    "user_profile_manager",
    "business_workflow_tool",
    "human_handoff_tool"
  ],
  "memory": {
    "provider": "honcho",
    "fallback": "postgresql",
    "context_window": 20
  },
  "channels": {
    "default": "test",
    "supported": ["facebook", "whatsapp", "test"]
  },
  "qualification_flow": {
    "steps": [
      "greeting",
      "service_interest",
      "budget_qualification",
      "timeline",
      "current_presence",
      "contact_capture"
    ],
    "scoring": {
      "budget_threshold_rm5k_plus": 2,
      "timeline_within_1_month": 2,
      "clear_service_requirement": 1,
      "qualified_threshold": 4,
      "warm_threshold": 2
    }
  }
}
