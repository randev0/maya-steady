# LeadQualBot systemd service
# Install: sudo cp /personalized_agent_bot/agent.service /etc/systemd/system/
#          sudo systemctl daemon-reload
#          sudo systemctl enable --now agent

[Unit]
Description=LeadQualBot — AI Lead Qualification Agent
After=network.target postgresql@16-main.service
Wants=postgresql@16-main.service

[Service]
Type=simple
User=selfops
Group=selfops
WorkingDirectory=/personalized_agent_bot

# Load environment variables from .env file
EnvironmentFile=/personalized_agent_bot/.env

# Use the virtualenv
ExecStart=/personalized_agent_bot/.venv/bin/uvicorn main:app \
    --host 0.0.0.0 \
    --port 8080 \
    --workers 2 \
    --log-level info \
    --access-log \
    --proxy-headers \
    --forwarded-allow-ips='*'

# Restart policy
Restart=on-failure
RestartSec=5
StartLimitInterval=60
StartLimitBurst=3

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/personalized_agent_bot

# Logging — viewable via: journalctl -u agent -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agent

[Install]
WantedBy=multi-user.target
