# LeadQualBot Environment Variables
# Copy to .env and fill in values before starting the service

# LLM — Maya customer runtime defaults to local Ollama + Qwen
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2

# Optional legacy/OpenRouter settings (manager agent still uses this path if enabled)
OPENROUTER_API_KEY=

# Database — local PostgreSQL installed on host
DATABASE_URL=postgresql://leadqualbot:CHANGE_THIS_PASSWORD@127.0.0.1:5432/leadqualbot

# Facebook Messenger (optional for MVP — leave blank to use test chat only)
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=leadqualbot_verify_2024
FB_APP_SECRET=

# Honcho conversational memory (optional — leave blank to use PostgreSQL only)
HONCHO_API_KEY=

# Lead export webhook (optional — push qualified leads to Google Sheets or CRM)
LEAD_EXPORT_WEBHOOK_URL=

# Admin protection for mutation endpoints
ADMIN_API_TOKEN=

# Optional owner alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Local WhatsApp gateway
WA_GATEWAY_BASE_URL=http://127.0.0.1:3001
FOLLOWUP_DISPATCH_INTERVAL_SECONDS=60
