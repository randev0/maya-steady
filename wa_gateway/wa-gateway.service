[Unit]
Description=WhatsApp Gateway — whatsapp-web.js bridge for Maya Steady
After=network.target agent.service

[Service]
Type=simple
User=selfops
WorkingDirectory=/opt/maya-steady/wa_gateway
ExecStart=/usr/bin/node gateway.js
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
